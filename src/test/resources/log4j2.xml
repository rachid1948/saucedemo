<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="C" target="SYSTEM_OUT"><PatternLayout pattern="%d{HH:mm:ss} %-5level %logger{36} - %msg%n"/></Console>
        <File name="F" fileName="logs/test.log" append="false"><PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %msg%n"/></File>
    </Appenders>
    <Loggers><Root level="info"><AppenderRef ref="C"/><AppenderRef ref="F"/></Root></Loggers>
</Configuration>
